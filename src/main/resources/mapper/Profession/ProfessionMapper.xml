<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.szh.sms.dao.Profession.ProfessionMapper" >
    <resultMap id="BaseUserMap" type="com.szh.sms.domain.Profession" >
        <result column="id" property="id" jdbcType="INTEGER" />
        <result column="name" property="name" jdbcType="VARCHAR" />
        <result column="course_count" property="courseCount" jdbcType="INTEGER" />
    </resultMap>
     <insert id="addProfession" parameterType="com.szh.sms.domain.Profession">
         <selectKey keyProperty="id" resultType="java.lang.Integer" order="AFTER">
             select LAST_INSERT_ID() as id
         </selectKey>
        INSERT INTO profession
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">`name`,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
        </trim>
    </insert>
    <delete id="deleteProfession" parameterType="int">
        DELETE FROM
        profession
        <where>
            id = #{id}
        </where>
    </delete>
    <update id="updateProfession" parameterType="com.szh.sms.domain.Profession">
        UPDATE profession
        <trim prefix="set" suffixOverrides=",">
            <if test="name != null and name != ''">
                `name` = #{name},
            </if>
        </trim>
        <where>
            id = #{id}
        </where>
    </update>
    <update id="updateStudentProfession">
        UPDATE student
        SET profession = #{newName}
        WHERE profession = #{oldName}
    </update>
    <update id="updateCourseProfession">
        UPDATE course
        SET profession = #{newName}
        WHERE profession = #{oldName}
    </update>
    <update id="updateTeacherCourseProfession">
        UPDATE teacher_course
        SET profession = #{newName}
        WHERE profession = #{oldName}
    </update>
    <update id="updateTimetableProfession">
        UPDATE timetable
        SET profession = #{newName}
        WHERE profession = #{oldName}
    </update>
    <update id="updateCourseInfoProfession">
        UPDATE course_info
        SET profession = #{newName}
        WHERE profession = #{oldName}
    </update>
    <select id="checkProfessionCount" resultType="int" parameterType="string">
        select count(0) from profession
        <where>
            name = #{name}
        </where>
    </select>
    <select id="getProfessionList" resultMap="BaseUserMap" parameterType="map">
        SELECT
            a.*,
            COUNT(b.id) AS course_count
        from profession a
        left join course b
        on a.name = b.profession
        GROUP BY a.id, a.name
        ORDER BY a.id
    </select>
    <select id="getProfessionById" resultMap="BaseUserMap" parameterType="int">
        SELECT
            *
        from profession
        where id = #{id}
    </select>
    <select id="countProfessionReferences" resultType="int" parameterType="string">
        SELECT
            (
                (SELECT COUNT(0) FROM student WHERE profession = #{name})
                + (SELECT COUNT(0) FROM course WHERE profession = #{name})
                + (SELECT COUNT(0) FROM teacher_course WHERE profession = #{name})
                + (SELECT COUNT(0) FROM timetable WHERE profession = #{name})
                + (SELECT COUNT(0) FROM course_info WHERE profession = #{name})
            )
    </select>

    <select id="getProfessionIdByName" resultMap="BaseUserMap" parameterType="string">
        SELECT
            id
        from profession
        where name = #{name}
    </select>
</mapper>
